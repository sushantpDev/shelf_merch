{
  "name": "shelfmerch",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @shelfmerch/api",
    "dev:web": "npm run dev -w @shelfmerch/web",
    "build": "npm run build -w @shelfmerch/web",
    "build:web": "npm run build -w @shelfmerch/web",
    "start": "npm run start -w @shelfmerch/api",
    "start:worker": "npm run worker -w @shelfmerch/api",
    "seed": "npm run seed -w @shelfmerch/api",
    "worker": "npm run worker -w @shelfmerch/api",
    "test": "npm test -w @shelfmerch/api"
  }
}

