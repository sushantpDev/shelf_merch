# A Dependabot bump landed typescript@7, which conflicts with typescript-eslint's
# `<6.1.0` peer range and makes `npm ci` fail its ERESOLVE check for everyone.
# Until the web toolchain majors are reconciled, resolve peers leniently so the
# lockfile installs consistently in CI and Docker. Remove once the web deps are
# reconciled (see the architecture plan's "Increment 1 — CI unblock" note).
legacy-peer-deps=true
