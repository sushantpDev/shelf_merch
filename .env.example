# --- Server ---
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
# Trusted reverse-proxy hops (Express trust proxy). Behind HAProxy = 1;
# behind Cloudflare -> HAProxy = 2. Must match the real topology or per-IP
# rate limits can be spoofed via X-Forwarded-For.
TRUST_PROXY=1

# --- Data stores ---
# MongoDB Atlas (required). MONGO_URL and MONGODB_URI are equivalent — use either.
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/shelfmerch
# Optional: Redis for login sessions, rate limiting, idempotency keys, BullMQ job queues.
# Sessions and idempotency fall back to MongoDB when Redis is unavailable; rate limits are skipped when Redis is down.
REDIS_URL=redis://localhost:6379

# --- Observability (Gap F) ---
# pino level: fatal|error|warn|info|debug|trace|silent
LOG_LEVEL=info
# Set to activate error reporting (requires `npm i @sentry/node`). Empty = disabled.
SENTRY_DSN=
# Set to enable distributed tracing (requires @opentelemetry/* packages). Empty = disabled.
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Auth ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Production example: https://shelfmerch.io/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL=
BASE_URL=
# SPA route that receives tokens after OAuth (e.g. https://shelfmerch.io/auth/google)
CLIENT_URL=

# --- File storage (Cloudflare R2, S3-compatible) — Phase 3+ ---
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=shelfmerch-assets

# --- File storage (AWS S3) — used when R2 is not configured ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=
# Optional custom domain or CloudFront base URL (e.g. https://shelfmerch.io)
S3_PUBLIC_BASE_URL=
# auto | local | s3 | r2 — use "local" when IAM lacks s3:PutObject
STORAGE_DRIVER=auto

# --- Payments (Razorpay sandbox) — Phase 7 ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- SMS / OTP (MSG91) — Phase 5 redemption + Phase 7 notifications ---
MSG91_AUTH_KEY=
MSG91_SENDER_ID=SLFMRH
MSG91_OTP_TEMPLATE_ID=

# --- Email — Phase 7 (Gmail SMTP or other nodemailer service) ---
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
APP_URL=http://localhost:8080
# Comma-separated CORS origins allowed in production. Empty NO LONGER means
# "allow all" — cross-origin requests are refused unless the Origin is listed
# here or matches the request Host (same-origin unified server still works).
CORS_ORIGINS=
# Production Content-Security-Policy mode: report-only (default, safe) | enforce | off.
# Validate report-only in staging, then set CSP_MODE=enforce.
CSP_MODE=report-only

# --- Frontend ---
VITE_API_URL=http://localhost:4000/api/v1
VITE_USE_MOCKS=false

# --- Production on VPS (e.g. 72.62.76.198) ---
# Copy deploy/env.production.template to .env on the server, then:
#   npm install && npm run build && pm2 start ecosystem.config.cjs
# Unified server on PORT=8080 serves API + SPA. Optional nginx on :80 → see deploy/nginx.conf.
# Production VITE_API_URL=/api/v1  (same-origin; set before `npm run build`)
